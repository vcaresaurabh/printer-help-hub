# Copy to .env.local and fill in when the owner provides real values.
# All are OPTIONAL — the site builds and renders correctly with them unset
# (chat, analytics, and ads simply stay dormant / are omitted).
#
# NEXT_PUBLIC_* values are inlined into the static export at build time.
# Do NOT put private secrets here — everything here ships to the browser.

# JivoChat live-chat widget id (from JivoChat dashboard)
NEXT_PUBLIC_JIVOCHAT_ID=

# Google Analytics 4 measurement id, e.g. G-XXXXXXXXXX
NEXT_PUBLIC_GA4_ID=

# Google Ads conversion id, e.g. AW-XXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_ID=

# Google Ads conversion label for the JivoChat lead event (name + phone submitted)
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=

# Optional: override the canonical site URL (defaults to https://printer-help-hub.com)
NEXT_PUBLIC_SITE_URL=
